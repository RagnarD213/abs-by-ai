# Anthropic API Key (Claude)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key
# Get one at https://aistudio.google.com/apikey
# Use the key linked to My Billing Account
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx

# Printify API Key
# Get one at: Printify dashboard → My Account → Connections → API
PRINTIFY_API_KEY=

# Printify Shop ID
# Found in Printify URL when your shop is selected: printify.com/app/shop/{SHOP_ID}/...
PRINTIFY_SHOP_ID=

# Stripe Secret Key (starts with sk_test_ or sk_live_)
# Get one at: Stripe dashboard → Developers → API Keys
STRIPE_SECRET_KEY=

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
# Same page as above — also paste this into STRIPE_PUBLISHABLE_KEY in index.html
STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook Signing Secret (starts with whsec_)
# Get one at: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=

# Postgres connection string (Railway → Postgres service → Variables → DATABASE_URL)
# Powers accounts, sessions, and cloud meal sync. When unset, login/signup are disabled.
DATABASE_URL=
